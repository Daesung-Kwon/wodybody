# 기존 .gitignore 내용 유지
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
ENV/
env/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
node_modules/
.env
.env.local
instance/
*.db

# Railway 마이그레이션 스크립트 (민감한 정보 포함)
migrate_railway.py

# BurnFat
burnfat/node_modules/
burnfat/dist/
burnfat/.wrangler/
burnfat/workers/*/node_modules/
burnfat/workers/*/dist/
burnfat/.env
burnfat/.env.local

# 루트의 lib/ ignore 규칙에서 BurnFat 소스 lib는 제외
!burnfat/src/lib/
!burnfat/src/lib/**
