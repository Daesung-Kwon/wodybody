# Railway 환경 변수 설정 가이드
# railway variables 명령어로 설정하거나 Railway 대시보드에서 설정

# 필수 환경 변수
DATABASE_URL=postgresql://postgres:password@localhost:5432/crossfit
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
SESSION_COOKIE_SECURE=true
CORS_ORIGINS=https://wodybody.com,https://www.wodybody.com

# 선택적 환경 변수
LOG_LEVEL=INFO
LOG_FILE=logs/crossfit.log
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=5

# 이메일 설정 (비밀번호 재설정 기능용)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# PostgreSQL 설정
POSTGRES_DB=crossfit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password

# BurnFat AI 조언 (Grok / xAI) 설정
# xAI 개발자 계정에서 발급받은 API Key
XAI_API_KEY=
# 모델명 (기본: grok-4-1-fast-non-reasoning — 저비용/고속, 체지방 코칭 문장 용도)
# 더 높은 품질이 필요하면 grok-4-1-fast-reasoning 또는 grok-4-0709 로 변경
XAI_MODEL=grok-4-1-fast-non-reasoning
# 응답 최대 토큰 / 호출 타임아웃(초)
XAI_MAX_TOKENS=300
XAI_TIMEOUT_SECONDS=30

# BurnFat 데이터 조회용 Supabase (AI 조언 컨텍스트 수집)
# Service Role Key는 절대 프론트엔드에 노출 금지 (백엔드 전용)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# BurnFat 프론트 서브도메인을 CORS에 추가 (CORS_ORIGINS에 함께 나열)
# 예: CORS_ORIGINS=https://wodybody.com,https://burnfat.wodybody.com,http://localhost:3000
