{
  "name": "wodybody-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "WODYBODY 모바일 셸 (Capacitor 7.x). webDir은 ../frontend/build를 가리킨다.",
  "scripts": {
    "build:web": "npm --prefix ../frontend run build",
    "sync": "npx cap sync",
    "copy": "npx cap copy",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "run:ios": "npm run build:web && npx cap copy ios && npx cap open ios",
    "run:android": "npm run build:web && npx cap copy android && npx cap open android",
    "doctor": "npx cap doctor"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "typescript": "^5.9.3"
  }
}
